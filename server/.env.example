# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/esd_review_portal

# JWT secret — use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# GIW admin credentials
# Dev: use GIW_ADMIN_PASSWORD (plaintext). Production: use GIW_ADMIN_PASSWORD_HASH (bcrypt).
GIW_ADMIN_EMAIL=admin@giw.com.au
GIW_ADMIN_PASSWORD=changeme
GIW_ADMIN_PASSWORD_HASH=

# Optional: email address to notify when a reviewer submits
GIW_NOTIFY_EMAIL=

# Nodemailer SMTP config
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="GIW Environmental Solutions <no-reply@example.com>"

# Frontend base URL — include the Vite base path in production, no trailing slash.
# Dev: http://localhost:5173
# Prod (GitHub Pages): https://inesbuskermolen-del.github.io/esdreviewportal
BASE_URL=http://localhost:5173

# Anthropic API key (for AI-assisted credit generation)
ANTHROPIC_API_KEY=

PORT=3001
